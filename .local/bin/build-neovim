#!/usr/bin/env bash
set -euo pipefail

# Detect OS
OS="$(uname -s)"
case "$OS" in
  Darwin) PLATFORM="macos" ;;
  Linux)  PLATFORM="linux" ;;
  *)      echo "Unsupported platform: $OS" >&2; exit 1 ;;
esac

# Check required dependencies
MISSING=()
check_dep() {
  command -v "$1" &>/dev/null || MISSING+=("$1")
}

check_dep git
check_dep cmake
check_dep make
check_dep cc

if [[ "$PLATFORM" == "macos" ]]; then
  # gettext provides msgfmt, needed by neovim's build
  command -v msgfmt &>/dev/null || MISSING+=("gettext")
fi

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo "Missing required dependencies: ${MISSING[*]}" >&2
  if [[ "$PLATFORM" == "macos" ]]; then
    echo "Install with: brew install ${MISSING[*]}" >&2
  else
    echo "Install with: sudo pacman -S base-devel cmake ninja lua-luv ${MISSING[*]}" >&2
  fi
  exit 1
fi

BUILDDIR="$(mktemp -d)"
trap 'rm -rf "$BUILDDIR"' EXIT

echo "Cloning neovim into $BUILDDIR..."
git clone --depth=1 --branch stable https://github.com/neovim/neovim.git "$BUILDDIR/neovim"

cd "$BUILDDIR/neovim"
echo "Building..."
make CMAKE_BUILD_TYPE=Release

echo "Installing to /usr/local..."
sudo make install
