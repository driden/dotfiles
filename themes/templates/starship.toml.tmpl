# generated by `theme build` — do not edit
"$schema" = 'https://starship.rs/config-schema.json'

command_timeout=100
#$c\
#$rust\
#$golang\
#$nodejs\
#$php\
#$kotlin\
#$haskell\
#$python\
format = """
[](keyword)\
$os\
$username\
[](bg:function fg:keyword)\
[](fg:function bg:property)\
$directory\
[](fg:property bg:type)\
[](fg:type bg:number)\
$git_branch\
$git_status\
[](fg:number bg:string)\
[](fg:string bg:function)\
$docker_context\
[ ](fg:function)\
$line_break$character"""

palette = 'theme'

[palettes.theme]
background           = "${palette.background}"
foreground           = "${palette.foreground}"
cursor               = "${palette.cursor}"
selection_background = "${palette.selection_background}"
selection_foreground = "${palette.selection_foreground}"
comment              = "${palette.comment}"
keyword              = "${palette.keyword}"
string               = "${palette.string}"
function             = "${palette.function}"
type                 = "${palette.type}"
number               = "${palette.number}"
variable             = "${palette.variable}"
constant             = "${palette.constant}"
operator             = "${palette.operator}"
property             = "${palette.property}"
parameter            = "${palette.parameter}"
error                = "${palette.error}"
warning              = "${palette.warning}"
info                 = "${palette.info}"
hint                 = "${palette.hint}"

[os]
disabled = false
style = "bg:keyword fg:background"

[os.symbols]
Windows = "󰍲"
Ubuntu = "󰕈"
SUSE = ""
Raspbian = "󰐿"
Mint = "󰣭"
Macos = ""
Manjaro = ""
Linux = "󰌽"
Gentoo = "󰣨"
Fedora = "󰣛"
Alpine = ""
Amazon = ""
Android = ""
Arch = "󰣇"
CachyOS = "󰣇"
Artix = "󰣇"
CentOS = ""
Debian = "󰣚"
Redhat = "󱄛"
RedHatEnterprise = "󱄛"

[username]
disabled = true
show_always = true
style_user = "bg:keyword fg:background"
style_root = "bg:keyword fg:background"
format = '[ $user ]($style)'

[directory]
style = "fg:background bg:property"
format = "[$path]($style)"
truncation_length = 1
fish_style_pwd_dir_length = 1
truncation_symbol = ""
truncate_to_repo = false

[git_branch]
symbol = ""
style = "bg:property"
format = '[[ $symbol $branch ](fg:background bg:number)]($style)'

[git_status]
style = "bg:property"
format = '[[($all_status$ahead_behind )](fg:background bg:number)]($style)'

[nodejs]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:background bg:property)]($style)'

[c]
symbol = " "
style = "bg:property"
format = '[[ $symbol( $version) ](fg:background bg:property)]($style)'

[rust]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:background bg:property)]($style)'

[golang]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:background bg:property)]($style)'

[php]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:foreground bg:property)]($style)'

[java]
symbol = " "
style = "bg:property"
format = '[[ $symbol( $version) ](fg:foreground bg:property)]($style)'

[kotlin]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:foreground bg:property)]($style)'

[haskell]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:foreground bg:property)]($style)'

[python]
symbol = ""
style = "bg:property"
format = '[[ $symbol( $version) ](fg:foreground bg:property)]($style)'

[docker_context]
symbol = ""
style = "bg:background"
format = '[[ $symbol( $context) ](fg:info bg:background)]($style)'

[time]
disabled = false
time_format = "%R"
style = "bg:keyword"
format = '[[  $time ](fg:background bg:keyword)]($style)'

[line_break]
disabled = false

[character]
disabled = false
success_symbol = '[](bold fg:string)'
error_symbol = '[](bold fg:error)'
vimcmd_symbol = '[](bold fg:string)'
vimcmd_replace_one_symbol = '[](bold fg:keyword)'
vimcmd_replace_symbol = '[](bold fg:keyword)'
vimcmd_visual_symbol = '[](bold fg:keyword)'
