# generated by `theme build` — do not edit
"$schema" = 'https://starship.rs/config-schema.json'

command_timeout = 100

format = """
[](accent)\
$os\
$username\
[](bg:color4 fg:accent)\
[](fg:color4 bg:color6)\
$directory\
[](fg:color6 bg:color3)\
[](fg:color3 bg:color9)\
$git_branch\
$git_status\
[](fg:color9 bg:color2)\
[](fg:color2 bg:color4)\
$docker_context\
[ ](fg:color4)\
$line_break$character"""

palette = 'theme'

[palettes.theme]
accent               = "${palette.accent}"
cursor               = "${palette.cursor}"
foreground           = "${palette.foreground}"
background           = "${palette.background}"
selection_foreground = "${palette.selection_foreground}"
selection_background = "${palette.selection_background}"
color0  = "${palette.color0}"
color1  = "${palette.color1}"
color2  = "${palette.color2}"
color3  = "${palette.color3}"
color4  = "${palette.color4}"
color5  = "${palette.color5}"
color6  = "${palette.color6}"
color7  = "${palette.color7}"
color8  = "${palette.color8}"
color9  = "${palette.color9}"
color10 = "${palette.color10}"
color11 = "${palette.color11}"
color12 = "${palette.color12}"
color13 = "${palette.color13}"
color14 = "${palette.color14}"
color15 = "${palette.color15}"

[os]
disabled = false
style = "bg:accent fg:background"

[os.symbols]
Windows = "󰍲"
Ubuntu = "󰕈"
SUSE = ""
Raspbian = "󰐿"
Mint = "󰣭"
Macos = ""
Manjaro = ""
Linux = "󰌽"
Gentoo = "󰣨"
Fedora = "󰣛"
Alpine = ""
Amazon = ""
Android = ""
Arch = "󰣇"
Artix = "󰣇"
CentOS = ""
Debian = "󰣚"
Redhat = "󱄛"
RedHatEnterprise = "󱄛"

[username]
disabled = true
show_always = true
style_user = "bg:accent fg:background"
style_root = "bg:accent fg:background"
format = '[ $user ]($style)'

[directory]
style = "fg:background bg:color6"
format = "[$path]($style)"
truncation_length = 1
fish_style_pwd_dir_length = 1
truncation_symbol = ""
truncate_to_repo = false

[git_branch]
symbol = ""
style = "bg:color6"
format = '[[ $symbol $branch ](fg:background bg:color9)]($style)'

[git_status]
style = "bg:color6"
format = '[[($all_status$ahead_behind )](fg:background bg:color9)]($style)'

[nodejs]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[c]
symbol = " "
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[rust]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[golang]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[php]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[java]
symbol = " "
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[kotlin]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[haskell]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[python]
symbol = ""
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:background bg:color6)]($style)'

[docker_context]
symbol = ""
style = "bg:color0"
format = '[[ $symbol( $context) ](fg:color4 bg:color8)]($style)'

[time]
disabled = false
time_format = "%R"
style = "bg:accent"
format = '[[  $time ](fg:background bg:accent)]($style)'

[line_break]
disabled = false

[character]
disabled = false
success_symbol = '[](bold fg:color2)'
error_symbol = '[](bold fg:color1)'
vimcmd_symbol = '[](bold fg:color2)'
vimcmd_replace_one_symbol = '[](bold fg:accent)'
vimcmd_replace_symbol = '[](bold fg:accent)'
vimcmd_visual_symbol = '[](bold fg:accent)'
