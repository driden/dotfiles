# generated by `theme build` — do not edit
# Sourced by ~/.tmux.conf via `source-file ~/.config/themes/current/tmux.conf`.
set -g status-style bg=${palette.background},fg=${palette.foreground}
set -g status-left-style bg=${palette.background},fg=${palette.foreground}
set -g status-right-style bg=${palette.background},fg=${palette.foreground}
set -g window-status-style bg=${palette.background},fg=${palette.color8}
set -g window-status-current-style bg=${palette.accent},fg=${palette.background}
set -g window-status-activity-style bg=${palette.background},fg=${palette.color3}
set -g pane-border-style fg=${palette.selection_background}
set -g pane-active-border-style fg=${palette.accent}
set -g message-style bg=${palette.background},fg=${palette.foreground}
set -g message-command-style bg=${palette.background},fg=${palette.foreground}
set -g mode-style bg=${palette.color3},fg=${palette.background}

set -g window-status-separator ""
set -g status-left ""
set -g status-right "#[fg=${palette.color6},bg=${palette.background}] #[bg=${palette.color6},fg=${palette.background}]#S#[fg=${palette.color6},bg=${palette.background}]"

set -g window-status-format "#[fg=${palette.color8},bg=${palette.background}] #W "
set -g window-status-current-format "#[fg=${palette.accent},bg=${palette.background}] #[fg=${palette.background},bg=${palette.accent}]#W#[fg=${palette.accent},bg=${palette.background}]"
